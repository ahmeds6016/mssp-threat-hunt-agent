{
  "swagger": "2.0",
  "info": {
    "title": "MSSP Threat Hunt Agent",
    "description": "Autonomous MSSP threat hunting agent powered by GPT-5.3-chat. Send any security question — the agent processes it asynchronously and returns a request_id to poll for the result. All intelligence is grounded in real Microsoft Sentinel data, MITRE ATT&CK, and CVE databases.",
    "version": "7.2.0"
  },
  "host": "mssphuntagent-fn.azurewebsites.net",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "function_key": {
      "type": "apiKey",
      "name": "code",
      "in": "query"
    }
  },
  "security": [{"function_key": []}],
  "x-ms-connector-metadata": [
    {
      "propertyName": "RequestTimeoutInMilliseconds",
      "propertyValue": "120000"
    }
  ],
  "paths": {
    "/api/v1/ask": {
      "post": {
        "operationId": "askAgent",
        "summary": "Submit a question to the threat hunt agent (returns immediately)",
        "description": "Send any security question or investigation request. Returns a request_id immediately (within 1 second). The agent processes the request in the background — use getAskResult to poll for the answer. Examples: 'Are we vulnerable to CVE-2024-3400?', 'Check for brute force in the last 7 days', 'Run a full threat hunt focused on ransomware'.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["message"],
              "properties": {
                "message": {
                  "type": "string",
                  "description": "The security question, investigation request, or threat hunting prompt",
                  "x-ms-summary": "Message"
                }
              }
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Request accepted — poll getAskResult with the request_id",
            "schema": {
              "type": "object",
              "properties": {
                "request_id": {
                  "type": "string",
                  "description": "Unique request ID to poll for the result (e.g., REQ-a1b2c3d4)",
                  "x-ms-summary": "Request ID"
                },
                "status": {
                  "type": "string",
                  "description": "Always 'processing' on initial submit",
                  "x-ms-summary": "Status"
                },
                "message": {
                  "type": "string",
                  "description": "Instructions for polling",
                  "x-ms-summary": "Message"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ask/{request_id}": {
      "get": {
        "operationId": "getAskResult",
        "summary": "Get the result of a submitted question",
        "description": "Poll this endpoint with the request_id from askAgent. Returns status 'processing' while the agent is working, or 'completed' with the full response when done. For simple queries this typically takes 15-45 seconds. If the result contains route='campaign', a deep investigation was started — use getCampaignProgress with the campaign_id to track live progress.",
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The request_id returned from askAgent (e.g., REQ-a1b2c3d4)",
            "x-ms-summary": "Request ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Request result (may be processing or completed)",
            "schema": {
              "type": "object",
              "properties": {
                "request_id": {
                  "type": "string",
                  "description": "The request identifier",
                  "x-ms-summary": "Request ID"
                },
                "status": {
                  "type": "string",
                  "description": "processing, completed, or error",
                  "x-ms-summary": "Status"
                },
                "route": {
                  "type": "string",
                  "description": "How the query was routed: 'chat' or 'campaign' (only present when completed)",
                  "x-ms-summary": "Route"
                },
                "response": {
                  "type": "string",
                  "description": "The agent's full analysis response in markdown (only present when completed)",
                  "x-ms-summary": "Response"
                },
                "campaign_id": {
                  "type": "string",
                  "description": "Campaign ID if routed to campaign — poll with getCampaign (only present for campaign route)",
                  "x-ms-summary": "Campaign ID"
                },
                "error": {
                  "type": "string",
                  "description": "Error message if status is 'error'",
                  "x-ms-summary": "Error"
                }
              }
            }
          },
          "404": {
            "description": "Request not found",
            "schema": {
              "type": "object",
              "properties": {
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/v1/campaigns/{campaign_id}/progress": {
      "get": {
        "operationId": "getCampaignProgress",
        "summary": "Get live campaign progress feed",
        "description": "Returns a real-time progress feed for a running or completed campaign. Shows which phase is active, every KQL query executed, every hypothesis being tested, every finding discovered, and budget usage. Use this whenever the user asks about campaign status, progress, what the agent is doing, or wants updates on a CAMP-ID. Returns immediately with the latest state — no waiting required.",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The campaign ID (e.g., CAMP-fd205f86)",
            "x-ms-summary": "Campaign ID"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 0,
            "description": "Return only events after this sequence number (0 = all events)",
            "x-ms-summary": "Since"
          }
        ],
        "responses": {
          "200": {
            "description": "Live campaign progress with event timeline",
            "schema": {
              "type": "object",
              "properties": {
                "campaign_id": {
                  "type": "string",
                  "description": "Campaign identifier",
                  "x-ms-summary": "Campaign ID"
                },
                "total_events": {
                  "type": "integer",
                  "description": "Total number of progress events logged so far",
                  "x-ms-summary": "Total Events"
                },
                "summary": {
                  "type": "object",
                  "description": "Compact status summary of the campaign",
                  "properties": {
                    "phase": {
                      "type": "string",
                      "description": "Current phase: index_refresh, hypothesize, execute, conclude, deliver, completed, or failed",
                      "x-ms-summary": "Current Phase"
                    },
                    "phases_completed": {
                      "type": "array",
                      "items": {"type": "string"},
                      "description": "List of phases that have finished",
                      "x-ms-summary": "Phases Completed"
                    },
                    "total_queries": {
                      "type": "integer",
                      "description": "Number of KQL queries executed so far",
                      "x-ms-summary": "Queries Run"
                    },
                    "total_findings": {
                      "type": "integer",
                      "description": "Number of findings discovered so far",
                      "x-ms-summary": "Findings"
                    },
                    "hypotheses": {
                      "type": "integer",
                      "description": "Number of hypotheses generated",
                      "x-ms-summary": "Hypotheses"
                    },
                    "last_event": {
                      "type": "string",
                      "description": "Type of the most recent event",
                      "x-ms-summary": "Last Event"
                    },
                    "last_detail": {
                      "type": "string",
                      "description": "Detail of the most recent event",
                      "x-ms-summary": "Last Detail"
                    }
                  },
                  "x-ms-summary": "Summary"
                },
                "events": {
                  "type": "array",
                  "description": "Timestamped progress events",
                  "items": {
                    "type": "object",
                    "properties": {
                      "seq": {"type": "integer", "description": "Sequence number"},
                      "t": {"type": "string", "description": "Timestamp (HH:MM:SS UTC)"},
                      "event": {"type": "string", "description": "Event type"}
                    }
                  },
                  "x-ms-summary": "Events"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/campaigns/{campaign_id}/report": {
      "get": {
        "operationId": "getCampaignReport",
        "summary": "Get the final campaign report",
        "description": "Returns the completed campaign report with executive summary, findings, recommendations, and MITRE ATT&CK mapping. Only available after the campaign status is 'completed'.",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The campaign ID",
            "x-ms-summary": "Campaign ID"
          },
          {
            "name": "format",
            "in": "query",
            "type": "string",
            "description": "Report format: json or markdown",
            "default": "json",
            "enum": ["json", "markdown"],
            "x-ms-summary": "Format"
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign report",
            "schema": {
              "type": "object",
              "properties": {
                "campaign_id": {
                  "type": "string",
                  "x-ms-summary": "Campaign ID"
                },
                "title": {
                  "type": "string",
                  "x-ms-summary": "Title"
                },
                "executive_summary": {
                  "type": "string",
                  "x-ms-summary": "Executive Summary"
                },
                "findings_count": {
                  "type": "object",
                  "properties": {
                    "true_positive": {"type": "integer"},
                    "false_positive": {"type": "integer"},
                    "inconclusive": {"type": "integer"}
                  },
                  "x-ms-summary": "Findings Count"
                },
                "risk_score": {
                  "type": "number",
                  "x-ms-summary": "Risk Score"
                },
                "recommendations": {
                  "type": "array",
                  "items": {"type": "string"},
                  "x-ms-summary": "Recommendations"
                }
              }
            }
          },
          "404": {
            "description": "Report not available yet",
            "schema": {
              "type": "object",
              "properties": {
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Check agent health and connectivity",
        "description": "Returns the agent's health status including LLM connectivity, Sentinel adapter status, and version information.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Agent health status",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "x-ms-summary": "Status"
                },
                "version": {
                  "type": "string",
                  "x-ms-summary": "Version"
                }
              }
            }
          }
        }
      }
    }
  }
}
