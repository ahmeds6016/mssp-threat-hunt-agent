# MSSP Hunt Agent — Environment Configuration
# Copy to .env and fill in values

# ── Execution Mode ──────────────────────────────────────────
HUNT_MOCK_MODE=true
HUNT_APPROVAL_REQUIRED=true
HUNT_ADAPTER_MODE=mock          # mock | real

# ── Paths ───────────────────────────────────────────────────
HUNT_OUTPUT_DIR=output
HUNT_CACHE_DIR=.cache/enrichment

# ── Query Defaults ──────────────────────────────────────────
HUNT_MAX_RESULTS=1000
HUNT_QUERY_TIMEOUT=30

# ── Exabeam New-Scale ───────────────────────────────────────
EXABEAM_CLIENT_ID=
EXABEAM_CLIENT_SECRET=
EXABEAM_REGION=us-west          # us-west | us-east | europe-west3 | asia-southeast1
EXABEAM_BASE_URL=               # Auto-constructed from region if empty

# ── Threat Intel Providers ──────────────────────────────────
HUNT_INTEL_PROVIDERS=mock       # mock | virustotal | abuseipdb (comma-separated)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ── Pivots ──────────────────────────────────────────────────
HUNT_ALLOW_PIVOTS=false
HUNT_MAX_PIVOT_QUERIES=5
